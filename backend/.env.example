# ── KYC / Sumsub ────────────────────────────────────────────
SUMSUB_SECRET_KEY=your_sumsub_secret_key_here
KYC_CONFIDENCE_THRESHOLD=0.95

# ── AWS Rekognition (신분증 얼굴 비교) ──────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
KYC_FACE_THRESHOLD=90.0
KYC_MAX_FILE_MB=10
KYC_HMAC_SECRET=change-me-in-production-use-256bit-random

# ── DeepL 번역 ──────────────────────────────────────────────
# 무료: api-free.deepl.com  /  유료: api.deepl.com (chat_ws.py에서 전환)
DEEPL_API_KEY=your_deepl_api_key_here
TRANSLATE_TIMEOUT_S=3.0

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_S=60

# ── TrueNote KYC ────────────────────────────────────────────
TRUENOTE_API_KEY=your_truenote_key
TRUENOTE_CONFIDENCE_THRESHOLD=0.90

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── PortOne (결제 — 백엔드) ──────────────────────────────────
PORTONE_API_SECRET=your_portone_api_secret           # V2 API Secret
PORTONE_STORE_ID=your_portone_store_id               # storeId (필요 시)
PORTONE_WEBHOOK_SECRET=your_portone_webhook_secret   # 웹훅 전용 시크릿 (미설정 시 API_SECRET 폴백)

# ── Solapi (SMS) ─────────────────────────────────────────────
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SENDER_PHONE=01000000000        # 발신 번호 (인증된 번호)
ADMIN_PHONE=01000000000         # 관리자 수신 번호

# ── 내부 API (스케줄러용) ────────────────────────────────────
INTERNAL_API_URL=http://localhost:8000
